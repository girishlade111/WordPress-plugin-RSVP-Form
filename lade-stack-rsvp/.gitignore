# =============================================================================
# .gitignore for Lade Stack RSVP Widget
# Prevents sensitive files from being committed to version control
# =============================================================================

# -----------------------------------------------------------------------------
# SECURITY: Never commit credentials or sensitive data
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.development
*.env
credentials.json
credentials.txt
passwords.txt
config.local.php
wp-config-local.php

# -----------------------------------------------------------------------------
# WordPress generated files (should not be in plugin repo)
# -----------------------------------------------------------------------------
wp-config.php
.htaccess
sitemap.xml
robots.txt

# -----------------------------------------------------------------------------
# IDE and Editor files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Log files
# -----------------------------------------------------------------------------
*.log
debug.log
error.log
php-error.log

# -----------------------------------------------------------------------------
# Cache and temporary files
# -----------------------------------------------------------------------------
cache/
tmp/
temp/
*.cache

# -----------------------------------------------------------------------------
# Upload and media files (if any)
# -----------------------------------------------------------------------------
uploads/
media/

# -----------------------------------------------------------------------------
# Node dependencies (if using build tools)
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Build output (if using compilation)
# -----------------------------------------------------------------------------
dist/
build/
*.min.js
*.min.css

# -----------------------------------------------------------------------------
# Database dumps (NEVER commit these!)
# -----------------------------------------------------------------------------
*.sql
*.sql.gz
database.sql
dump.sql

# -----------------------------------------------------------------------------
# Backup files
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old

# -----------------------------------------------------------------------------
# Test credentials (use .example files instead)
# -----------------------------------------------------------------------------
test-credentials.json
test.env
api-keys.txt

# -----------------------------------------------------------------------------
# OpenSSL and security certificates
# -----------------------------------------------------------------------------
*.key
*.pem
*.crt
*.p12
private.key

# -----------------------------------------------------------------------------
# Composer (if used)
# -----------------------------------------------------------------------------
/vendor/
composer.lock

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# ✅ DO commit: Source code, README, documentation, .gitignore
# ❌ DON'T commit: Credentials, .env files, logs, cache, database dumps
# =============================================================================
