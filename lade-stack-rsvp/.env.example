# =================================================================
# LADE STACK RSVP WIDGET - CREDENTIALS TEMPLATE
# =================================================================
# ⚠️ SECURITY WARNING:
# - NEVER commit this file with actual values to version control
# - Copy this to .env (gitignored) or store credentials securely
# - Use WordPress options table for production credentials
# =================================================================

# =================================================================
# WORDPRESS ADMIN CREDENTIALS
# Store in: WordPress Database (wp_options) or Environment Variables
# =================================================================
WP_ADMIN_EMAIL=your-email@example.com
WP_ADMIN_USERNAME=your-username
WP_ADMIN_PASSWORD=your-secure-password
WP_SITE_URL=https://your-wordpress-site.com

# =================================================================
# EMAILJS CREDENTIALS (For Email Confirmations)
# Get from: https://dashboard.emailjs.com/
# Store in: WordPress Admin → Lade Stack RSVP Settings
# =================================================================
EMAILJS_SERVICE_ID=service_xxx          # e.g., service_gmail123
EMAILJS_TEMPLATE_ID=template_xxx        # e.g., template_rsvp456
EMAILJS_PUBLIC_KEY=user_xxx             # e.g., user_abc123xyz

# =================================================================
# GOOGLE ANALYTICS (For Event Tracking)
# Get from: https://analytics.google.com/
# =================================================================
GA_TRACKING_ID=G-XXXXXXXXXX             # e.g., G-A1B2C3D4E5
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =================================================================
# ADMIN DASHBOARD PASSWORD
# Default: ladestack123 (CHANGE THIS!)
# Store in: WordPress Admin or Shortcode Attribute
# =================================================================
RSVP_ADMIN_PASSWORD=your-custom-password-here

# =================================================================
# DATABASE CREDENTIALS (WordPress handles this automatically)
# Store in: wp-config.php (NEVER in .env for WordPress)
# =================================================================
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_HOST=localhost

# =================================================================
# SECURITY KEYS (WordPress generates these automatically)
# Store in: wp-config.php
# =================================================================
# AUTH_KEY=your-unique-phrase-here
# SECURE_AUTH_KEY=your-unique-phrase-here
# LOGGED_IN_KEY=your-unique-phrase-here
# NONCE_KEY=your-unique-phrase-here

# =================================================================
# SMTP CREDENTIALS (Alternative to EmailJS)
# If using WordPress SMTP plugin
# =================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_ENCRYPTION=tls

# =================================================================
# USAGE INSTRUCTIONS
# =================================================================
# 1. Copy this file to .env (add .env to .gitignore)
# 2. Replace placeholder values with your actual credentials
# 3. For WordPress plugins, use WordPress Admin panel instead:
#    - Go to: WordPress Admin → Settings → Lade Stack RSVP
#    - Enter EmailJS credentials there (stored securely in wp_options)
# 4. NEVER commit credentials to Git/GitHub
# 5. Use environment variables in production
# =================================================================

# =================================================================
# SECURE STORAGE RECOMMENDATIONS
# =================================================================
# ✅ DO:
#    - Use WordPress Options API (get_option/update_option)
#    - Use environment variables (.env with phpdotenv)
#    - Use WordPress constants in wp-config.php
#    - Use a secrets manager (AWS Secrets Manager, Vault)
#
# ❌ DON'T:
#    - Store credentials in code files
#    - Commit .env to version control
#    - Share credentials via email/chat
#    - Use default passwords in production
# =================================================================
